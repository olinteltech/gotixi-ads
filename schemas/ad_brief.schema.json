{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GoTixi Ad Brief",
  "description": "Input brief that Claude receives before generating ad copy",
  "type": "object",
  "required": ["destination", "audience_segment", "offer", "image_path"],
  "additionalProperties": false,
  "properties": {
    "destination": {
      "type": "string",
      "minLength": 2,
      "description": "Travel destination, e.g. 'Bali', 'Switzerland', 'Japan'"
    },
    "audience_segment": {
      "type": "string",
      "enum": ["families", "couples", "solo_explorers", "adventurers", "luxury_travelers", "first_timers"],
      "description": "GoTixi Duckling audience segment"
    },
    "offer": {
      "type": "string",
      "minLength": 5,
      "description": "Experience or package angle — no price framing"
    },
    "image_path": {
      "type": "string",
      "description": "Local filesystem path to the ad image (JPG or PNG, min 600x314px, max 30MB)"
    },
    "campaign_objective": {
      "type": "string",
      "enum": [
        "OUTCOME_TRAFFIC",
        "OUTCOME_LEADS",
        "OUTCOME_AWARENESS",
        "OUTCOME_ENGAGEMENT",
        "OUTCOME_SALES"
      ],
      "default": "OUTCOME_TRAFFIC",
      "description": "Meta campaign objective"
    },
    "daily_budget_inr": {
      "type": "number",
      "minimum": 100,
      "default": 500,
      "description": "Daily budget in INR (rupees, not paise — conversion handled by script)"
    },
    "cta_button": {
      "type": "string",
      "enum": ["LEARN_MORE", "BOOK_TRAVEL", "CONTACT_US", "GET_QUOTE", "SIGN_UP"],
      "default": "LEARN_MORE",
      "description": "Meta CTA button type"
    },
    "link_url": {
      "type": "string",
      "format": "uri",
      "description": "Override destination URL (defaults to GOTIXI_LINK_URL env var)"
    },
    "targeting": {
      "type": "object",
      "description": "Optional targeting overrides",
      "properties": {
        "countries": {
          "type": "array",
          "items": { "type": "string", "minLength": 2, "maxLength": 2 },
          "default": ["IN"],
          "description": "ISO 3166-1 alpha-2 country codes"
        },
        "age_min": { "type": "integer", "minimum": 18, "maximum": 65, "default": 25 },
        "age_max": { "type": "integer", "minimum": 18, "maximum": 65, "default": 55 },
        "genders": {
          "type": "array",
          "items": { "type": "integer", "enum": [0, 1, 2] },
          "default": [],
          "description": "0=all, 1=male, 2=female"
        }
      }
    }
  }
}
