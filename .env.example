# GoTixi Meta Ads — Credentials
# Copy this to .env and fill in your values. Never commit .env.

META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_        # Must include the act_ prefix
META_PAGE_ID=

# Optional: destination URL for ad links (defaults to gotixi.com)
GOTIXI_LINK_URL=https://gotixi.com
